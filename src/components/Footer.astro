---
// 静态页脚 - 链接 href 固定，显示文字用客户端 script 切换双语
const year = new Date().getFullYear();
---

<footer
  class="border-t mt-20"
  style="border-color: var(--border); background: var(--bg-2);"
>
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
    <div style="color: var(--text-muted);">
      © {year}
      <span data-zh="Momo工具箱" data-en="Momo Toolbox">Momo工具箱</span>
      ·
      <span data-zh="所有数据浏览器本地处理" data-en="All data processed locally">所有数据浏览器本地处理</span>
    </div>
    <nav class="flex items-center gap-5 flex-wrap justify-center">
      <a
        href="/about/"
        class="transition-colors hover:opacity-70"
        style="color: var(--text-muted);"
        data-zh="关于我们"
        data-en="About"
      >关于我们</a>
      <a
        href="/faq/"
        class="transition-colors hover:opacity-70"
        style="color: var(--text-muted);"
        data-zh="常见问题"
        data-en="FAQ"
      >常见问题</a>
      <a
        href="/privacy/"
        class="transition-colors hover:opacity-70"
        style="color: var(--text-muted);"
        data-zh="隐私政策"
        data-en="Privacy Policy"
      >隐私政策</a>
      <a
        href="/terms/"
        class="transition-colors hover:opacity-70"
        style="color: var(--text-muted);"
        data-zh="服务条款"
        data-en="Terms of Service"
      >服务条款</a>
      <a
        href="mailto:1902243211@qq.com"
        class="transition-colors hover:opacity-70"
        style="color: var(--text-muted);"
        data-zh="联系邮箱"
        data-en="Contact Email"
      >联系邮箱</a>
    </nav>
  </div>

  {/* 关于 Momo 工具箱:SEO 简介 + 内部链接,放页脚所有页面共享 */}
  <div class="max-w-5xl mx-auto px-6 pb-8 pt-2" style="border-top: 1px solid var(--border); margin-top: 1rem; padding-top: 1.5rem;">
    <h2 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--text);">
      <span data-zh="关于 Momo 工具箱" data-en="About Momo Toolbox">关于 Momo 工具箱</span>
    </h2>
    <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.875rem; margin-bottom: 0.75rem;">
      <span data-zh="Momo 工具箱是一个免费的在线工具集合,提供 JSON 格式化、Markdown 编辑器、二维码生成、密码生成器、Base64 编解码、URL 编解码、时间戳转换、哈希生成器、JWT 解码、UUID 生成、颜色转换、单位换算、HTTP 状态码查询、图片压缩、图片分割、AI 抠图、AES/SM4 加密、屏幕录制、番茄钟、全屏时钟、随机分组等 21 个实用工具。所有数据均在浏览器本地处理,不上传服务器,保护隐私。" data-en="Momo Toolbox is a free online tool collection offering 21 practical utilities including JSON formatter, Markdown editor, QR code generator, password generator, Base64 encoder, URL encoder, timestamp converter, hash generator, JWT decoder, UUID generator, color converter, unit converter, HTTP status codes, image compressor, image splitter, AI background removal, AES/SM4 encryption, screen recorder, pomodoro timer, fullscreen clock, and random grouping. All data is processed locally in your browser, never uploaded, protecting your privacy.">Momo 工具箱是一个免费的在线工具集合,提供 JSON 格式化、Markdown 编辑器、二维码生成、密码生成器、Base64 编解码、URL 编解码、时间戳转换、哈希生成器、JWT 解码、UUID 生成、颜色转换、单位换算、HTTP 状态码查询、图片压缩、图片分割、AI 抠图、AES/SM4 加密、屏幕录制、番茄钟、全屏时钟、随机分组等 21 个实用工具。所有数据均在浏览器本地处理,不上传服务器,保护隐私。</span>
    </p>
    <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.875rem;">
      <span data-zh="基于 Astro + React + TypeScript 构建,部署在 Cloudflare Pages 全球 CDN,支持中英双语、暗黑模式、PWA 桌面安装。每个工具都配有详细的使用教程和常见问题解答,适合开发者、设计师、内容创作者和日常办公用户。" data-en="Built with Astro + React + TypeScript, deployed on Cloudflare Pages global CDN, supporting bilingual Chinese/English, dark mode, and PWA desktop installation. Each tool comes with a detailed tutorial and FAQ, designed for developers, designers, content creators, and everyday office users.">基于 Astro + React + TypeScript 构建,部署在 Cloudflare Pages 全球 CDN,支持中英双语、暗黑模式、PWA 桌面安装。每个工具都配有详细的使用教程和常见问题解答,适合开发者、设计师、内容创作者和日常办公用户。</span>
    </p>
  </div>
</footer>

<script is:inline>
  (function () {
    function applyLang(lang) {
      if (lang !== 'zh' && lang !== 'en') return;
      // 切换单元素双语文字
      document.querySelectorAll('[data-zh][data-en]').forEach(function (el) {
        el.textContent = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-zh');
      });
      // 切换整块双语区块：清掉所有 inline display，让 CSS 的 html[data-lang] 规则接管
      // （LanguageContext 已经同步设置了 <html data-lang>，CSS 会自动隐藏非当前语言区块）
      document.querySelectorAll('[data-lang]').forEach(function (el) {
        el.style.display = '';
      });
    }
    try {
      var lang = localStorage.getItem('momo-lang') || 'zh';
      applyLang(lang);
      window.addEventListener('momo-lang-change', function (e) {
        // detail 可能是字符串（LanguageContext 直接传 lang）也可能是对象 { lang }
        var next = e.detail;
        if (typeof next === 'object' && next) next = next.lang;
        applyLang(next);
      });
    } catch (e) {}
  })();
</script>
