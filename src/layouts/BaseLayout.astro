---
import '@/styles/globals.css';
import AppShell from '../components/AppShell.tsx';
import Footer from '../components/Footer.astro';
import type { Language } from '../i18n/translations';

export interface Props {
  title?: string;
  description?: string;
  lang?: Language;
  canonical?: string;
  ogImage?: string;
  // SEO 关键词:传入则输出 <meta name="keywords">,中英双语页面按需传入对应语言
  keywords?: string[];
  // 文章类页面（教程/博客/法律页）专用 meta，普通工具页不传
  articleMeta?: {
    author?: string;
    section?: string;
    tags?: string[];
    publishedTime?: string; // ISO 8601
    modifiedTime?: string; // ISO 8601
  };
}

const {
  title = 'Momo工具箱 - 极速、专业的在线工具集合',
  description = '所有数据浏览器本地处理，即开即用，保护隐私。',
  lang = 'zh',
  canonical,
  ogImage = '/og-image.svg',
  keywords,
  articleMeta,
} = Astro.props;

const fullCanonical = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const fullOgImage = new URL(ogImage, Astro.site).toString();
const altLang = lang === 'zh' ? 'en' : 'zh';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <link rel="canonical" href={fullCanonical} />

    <!-- hreflang: 声明中英双语版本 -->
    <link rel="alternate" hreflang="zh" href={fullCanonical} />
    <link rel="alternate" hreflang="en" href={fullCanonical} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />

    <!-- PWA -->
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#d97706" />

    {/* Google AdSense:声明发布商账号 */}
    <meta name="google-adsense-account" content="ca-pub-1315335444091074" />

    {/* Google AdSense:加载广告库(全站共享,只加载一次) */}
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1315335444091074"
      crossorigin="anonymous"
    ></script>

    {/* Open Graph：文章类页面用 article，其余用 website（og:type 只能出现一次） */}
    <meta property="og:type" content={articleMeta ? 'article' : 'website'} />
    <meta property="og:site_name" content="Momo Toolbox" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Momo Toolbox - Online Tools" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_CN'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content="Momo Toolbox - Online Tools" />

    {/* 文章类页面专用 Open Graph article meta（仅当 articleMeta 传入时输出；og:type 已在上方条件渲染） */}
    {articleMeta && (
      <>
        <meta property="article:author" content={articleMeta.author || 'Momo Toolbox'} />
        <meta property="article:section" content={articleMeta.section || 'Tutorial'} />
        {articleMeta.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
        {articleMeta.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
        {(articleMeta.tags || []).map(tag => <meta property="article:tag" content={tag} />)}
      </>
    )}

    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Lora:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- 初始化语言（SSR 默认中文，客户端挂载后由 LanguageProvider 覆盖） -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('momo-lang') || 'zh';
          if (saved === 'en' || saved === 'zh') {
            document.documentElement.lang = saved;
            // 提前隐藏非当前语言的静态区块，避免闪烁
            document.documentElement.setAttribute('data-lang', saved);
          }
        } catch (e) {}
      })();
    </script>

    <!-- 初始化主题（在 React hydrate 前应用，避免明暗闪烁） -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('momo-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (e) {}
      })();
    </script>

    <!-- 注册 Service Worker (PWA 离线 + 可安装到桌面) -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js', { scope: '/' })
            .catch(function (err) {
              console.warn('[PWA] Service Worker 注册失败:', err);
            });
        });
      }
    </script>
  </head>
  <body>
    <AppShell client:load />
    <main>
      <slot />
    </main>
    {/* 移动端 AdSense 信息流广告:< 1280px 显示,桌面端用两侧 fixed 广告避免重复 */}
    <aside class="mobile-in-feed-ad" aria-hidden="true">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="fluid"
        data-ad-layout-key="-hi+e-a-53+a7"
        data-ad-client="ca-pub-1315335444091074"
        data-ad-slot="8459866523"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <Footer />

    {/* 两侧 AdSense 广告位:桌面端(≥1280px)固定显示在主内容两侧空白处,
        移动端隐藏避免遮挡主内容(AdSense 政策要求) */}
    <aside class="side-ad side-ad-left" aria-hidden="true">
      <ins
        class="adsbygoogle"
        style="display:block;width:160px;height:600px"
        data-ad-client="ca-pub-1315335444091074"
        data-ad-slot="5253294852"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
    <aside class="side-ad side-ad-right" aria-hidden="true">
      <ins
        class="adsbygoogle"
        style="display:block;width:160px;height:600px"
        data-ad-client="ca-pub-1315335444091074"
        data-ad-slot="5253294852"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <style>
      /* 移动端信息流广告:占满主内容宽度,显示在 Footer 之前的内容流末尾 */
      .mobile-in-feed-ad {
        display: none;
        max-width: 56rem;
        margin: 1.5rem auto;
        padding: 0 1.5rem;
      }
      /* 仅在 < 1280px 时显示(桌面端用两侧 fixed 广告,避免重复投放) */
      @media (max-width: 1279px) {
        .mobile-in-feed-ad {
          display: block;
        }
      }

      /* 侧边广告位定位:固定在主内容(56rem≈896px)两侧,顶部留 88px 避开 Header */
      .side-ad {
        position: fixed;
        top: 88px;
        width: 160px;
        height: 600px;
        z-index: 5;
        display: none;
      }
      .side-ad-left {
        left: calc(50% - 624px); /* 448(主内容左半) + 16(间距) + 160(广告宽) = 624 */
      }
      .side-ad-right {
        right: calc(50% - 624px);
      }
      /* 仅在视口宽度 ≥1280px 时显示(主内容 896 + 两侧广告 320 + 间距 32 ≈ 1248) */
      @media (min-width: 1280px) {
        .side-ad {
          display: block;
        }
      }
    </style>

    <!-- Web Vitals 上报(生产环境自动启用,本地开发不上报) -->
    <script src="/vitals.js" defer></script>
  </body>
</html>