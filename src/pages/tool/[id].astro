---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolContent from '../../components/ToolContent.tsx';
import { TOOLS, getToolById } from '../../constants';
import { TOOL_TUTORIALS } from '../../data/toolTutorials';

// 为每个工具生成静态页面
export function getStaticPaths() {
  return TOOLS.map(tool => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;

// SEO 元数据
const title = tool.seoTitle?.zh || `${tool.name.zh} - Momo工具箱`;
const description = tool.seoDescription?.zh || tool.description.zh;
const canonical = new URL(`/tool/${tool.id}/`, Astro.site).toString();

// 教程数据:用于在工具页底部展示文字内容(AdSense 高质量内容要求)
const tutorial = TOOL_TUTORIALS[tool.id];

// 相关工具:同分类的其他工具(最多 5 个),用于内部链接传递权重
// 如果同类不足 5 个,补充其他类别的工具凑齐
const sameCategory = TOOLS.filter(t => t.category === tool.category && t.id !== tool.id);
const others = TOOLS.filter(t => t.category !== tool.category && t.id !== tool.id);
const relatedTools = [...sameCategory, ...others].slice(0, 5);

// JSON-LD 结构化数据（SoftwareApplication schema + FAQPage schema）
const faqLdEntries = tutorial?.faq?.zh?.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) || [];
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name.zh,
  description: tool.description.zh,
  applicationCategory: 'Utility',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  url: canonical,
};
const faqLd = faqLdEntries.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqLdEntries,
} : null;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  {/* 静态 SEO 主标题：双语切换，保证页面有且仅有一个 h1（React 岛内显示同名 h2） */}
  <h1 class="sr-only">
    <span data-zh={tool.seoTitle?.zh || `${tool.name.zh} - Momo工具箱`} data-en={tool.seoTitle?.en || `${tool.name.en} - Momo Toolbox`}>{tool.seoTitle?.zh || `${tool.name.zh} - Momo工具箱`}</span>
  </h1>
  <ToolContent tool={tool} client:load />

  {/* 工具详细介绍:AdSense 要求工具页有实质文字内容,不能只有 UI */}
  {tutorial && (
    <section class="tool-detail-content" style="max-width: 56rem; margin: 2rem auto; padding: 1.5rem;">
      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">
        <span data-zh={`${tool.name.zh} - 使用场景`} data-en={`${tool.name.en} - Use Cases`}>{tool.name.zh} - 使用场景</span>
      </h2>
      <p style="color: var(--text); line-height: 1.7; margin-bottom: 1.5rem;">
        <span data-zh={tutorial.usage.zh} data-en={tutorial.usage.en}>{tutorial.usage.zh}</span>
      </p>

      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">
        <span data-zh="功能特点" data-en="Features">功能特点</span>
      </h2>
      <ul style="color: var(--text); line-height: 1.8; margin-bottom: 1.5rem; padding-left: 1.5rem; list-style: disc;">
        {tutorial.features.zh.map(f => (
          <li><span data-zh={f} data-en={tutorial.features.en[tutorial.features.zh.indexOf(f)] || f}>{f}</span></li>
        ))}
      </ul>

      {tutorial.faq.zh.length > 0 && (
        <>
          <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">
            <span data-zh="常见问题" data-en="FAQ">常见问题</span>
          </h2>
          <div style="color: var(--text); line-height: 1.7;">
            {tutorial.faq.zh.map(f => (
              <div style="margin-bottom: 1rem;">
                <h3 style="font-weight: 600; margin-bottom: 0.5rem;">
                  <span data-zh={f.q} data-en={(tutorial.faq.en[tutorial.faq.zh.indexOf(f)] || {}).q || f.q}>{f.q}</span>
                </h3>
                <p style="color: var(--text-muted);">
                  <span data-zh={f.a} data-en={(tutorial.faq.en[tutorial.faq.zh.indexOf(f)] || {}).a || f.a}>{f.a}</span>
                </p>
              </div>
            ))}
          </div>
        </>
      )}

      <p style="margin-top: 1.5rem; padding: 0.75rem 1rem; background: var(--bg-3); border-radius: 0.5rem; color: var(--text-muted); font-size: 0.875rem;">
        <span data-zh="想了解更多?查看完整 " data-en="Want more details? See the full ">想了解更多?查看完整 </span>
        <a href={`/tutorial/${tool.id}/`} style="color: var(--accent); text-decoration: underline;">
          <span data-zh={`${tool.name.zh} 使用教程`} data-en={`${tool.name.en} Tutorial`}>{tool.name.zh} 使用教程</span>
        </a>
      </p>
    </section>
  )}

  {/* 相关工具:内部链接传递权重,帮助 Googlebot 发现更多工具页 */}
  <section class="related-tools" style="max-width: 56rem; margin: 2rem auto; padding: 1.5rem; border-top: 1px solid var(--border);">
    <h2 class="related-title" style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">
      <span data-zh="相关工具" data-en="Related Tools">相关工具</span>
    </h2>
    <div class="related-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem;">
      {relatedTools.map(t => (
        <a
          href={`/tool/${t.id}/`}
          style="display: block; padding: 0.75rem 1rem; border-radius: 0.5rem; background: var(--bg-3); border: 1px solid var(--border); color: var(--text); text-decoration: none; transition: all 0.2s;"
          onmouseover="this.style.borderColor='var(--accent)'"
          onmouseout="this.style.borderColor='var(--border)'"
        >
          <div style="font-weight: 500; font-size: 0.875rem;">
            <span data-zh={t.name.zh} data-en={t.name.en}>{t.name.zh}</span>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
            <span data-zh={t.description.zh} data-en={t.description.en}>{t.description.zh}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
