---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOOLS, getToolById } from '../../constants';
import { TOOL_TUTORIALS } from '../../data/toolTutorials';

// 为每个有教程的工具生成静态页面
export function getStaticPaths() {
  return TOOLS.filter(tool => TOOL_TUTORIALS[tool.id]).map(tool => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const tutorial = TOOL_TUTORIALS[tool.id];
if (!tutorial) {
  return Astro.redirect('/404');
}

const title = tutorial.seoTitle.zh;
const description = tutorial.seoDescription.zh;
const canonical = new URL(`/tutorial/${tool.id}`, Astro.site).toString();

// JSON-LD 结构化数据（HowTo schema）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${tool.name.zh} 使用教程`,
  description: tutorial.usage.zh,
  inLanguage: 'zh-CN',
  totalTime: 'PT5M',
  supply: [{
    '@type': 'HowToSupply',
    name: '支持现代浏览器的设备',
  }],
  tool: [{
    '@type': 'HowToTool',
    name: tool.name.zh,
  }],
  step: tutorial.examples.zh.map((example, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: `使用示例 ${i + 1}`,
    text: example,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="legal-page" style="max-width: 48rem;">
    <!-- 面包屑导航 -->
    <nav class="flex items-center gap-2 text-xs mb-6" style="color: var(--text-muted);">
      <a href="/" style="color: var(--text-muted);" data-zh="首页" data-en="Home">首页</a>
      <span>/</span>
      <a href={`/tool/${tool.id}/`} style="color: var(--text-muted);" data-zh={tool.name.zh} data-en={tool.name.en}>{tool.name.zh}</a>
      <span>/</span>
      <span style="color: var(--text);" data-zh="教程" data-en="Tutorial">教程</span>
    </nav>

    <!-- 标题 -->
    <div data-lang="zh">
      <h1 style="margin-bottom: 0.5rem;">{tool.name.zh} 使用教程</h1>
      <p class="updated">详细使用指南、最佳实践与常见问题解答</p>
    </div>
    <div data-lang="en">
      <h1 style="margin-bottom: 0.5rem;">{tool.name.en} Tutorial</h1>
      <p class="updated">Detailed guide, best practices, and FAQ</p>
    </div>

    <!-- 立即使用按钮 -->
    <div style="margin: 2rem 0; padding: 1.5rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 1rem; text-align: center;">
      <a
        href={`/tool/${tool.id}/`}
        style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: var(--accent); color: #fff; border-radius: 0.75rem; font-weight: 600; text-decoration: none; box-shadow: 0 4px 12px rgba(var(--accent-rgb), 0.3);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
        <span data-zh="立即使用此工具" data-en="Use this tool now">立即使用此工具</span>
      </a>
    </div>

    <!-- 使用场景 -->
    <div data-lang="zh">
      <h2>使用场景</h2>
      <p>{tutorial.usage.zh}</p>
    </div>
    <div data-lang="en">
      <h2>Use Cases</h2>
      <p>{tutorial.usage.en}</p>
    </div>

    <!-- 功能特点 -->
    <div data-lang="zh">
      <h2>功能特点</h2>
      <ul>
        {tutorial.features.zh.map(feature => <li>{feature}</li>)}
      </ul>
    </div>
    <div data-lang="en">
      <h2>Features</h2>
      <ul>
        {tutorial.features.en.map(feature => <li>{feature}</li>)}
      </ul>
    </div>

    <!-- 使用示例 -->
    <div data-lang="zh">
      <h2>使用示例</h2>
      {tutorial.examples.zh.map((example, i) => (
        <p><strong>示例 {i + 1}：</strong>{example}</p>
      ))}
    </div>
    <div data-lang="en">
      <h2>Examples</h2>
      {tutorial.examples.en.map((example, i) => (
        <p><strong>Example {i + 1}:</strong> {example}</p>
      ))}
    </div>

    <!-- 最佳实践 -->
    <div data-lang="zh">
      <h2>最佳实践</h2>
      <ul>
        {tutorial.bestPractices.zh.map(tip => <li>{tip}</li>)}
      </ul>
    </div>
    <div data-lang="en">
      <h2>Best Practices</h2>
      <ul>
        {tutorial.bestPractices.en.map(tip => <li>{tip}</li>)}
      </ul>
    </div>

    <!-- 常见问题 -->
    <div data-lang="zh">
      <h2>常见问题</h2>
      {tutorial.faq.zh.map(item => (
        <div style="margin-bottom: 1.5rem;">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--accent);">{item.q}</h3>
          <p>{item.a}</p>
        </div>
      ))}
    </div>
    <div data-lang="en">
      <h2>FAQ</h2>
      {tutorial.faq.en.map(item => (
        <div style="margin-bottom: 1.5rem;">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--accent);">{item.q}</h3>
          <p>{item.a}</p>
        </div>
      ))}
    </div>

    <!-- 底部 CTA -->
    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <a href={`/tool/${tool.id}/`} style="color: var(--accent); text-decoration: underline;" data-zh="← 立即使用工具" data-en="← Use this tool">← 立即使用工具</a>
      <a href="/" style="color: var(--text-muted); text-decoration: underline;" data-zh="返回首页" data-en="Back to Home">返回首页</a>
    </div>
  </article>
</BaseLayout>
